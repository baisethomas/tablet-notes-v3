{
  "version": 2,
  "functions": {
    "api/transcribe.js": {
      "maxDuration": 60
    },
    "api/summarize.js": {
      "maxDuration": 60
    }
  },
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/$1"
    }
  ]
}